-- ===== k=1, k=2 verified from the stationary chain (previous step) =====
def pi1 : Fin 2 → ℚ
  | 0 => 1/3
  | 1 => 2/3
def X1 : ℚ := 3 * (pi1 0 ^ 2 + pi1 1 ^ 2)
def S1 : ℚ := X1 - 1
example : S1 = 2/3 := by unfold S1 X1 pi1; norm_num

def pi2 : Fin 6 → ℚ
  | 0 => 8/63 | 1 => 16/63 | 2 => 11/63
  | 3 => 4/63 | 4 => 2/63  | 5 => 22/63
def X2 : ℚ := 9 * (pi2 0^2 + pi2 1^2 + pi2 2^2 + pi2 3^2 + pi2 4^2 + pi2 5^2)
def S2 : ℚ := X2 - X1
example : S2 = 10/21 := by unfold S2 X2 X1 pi2 pi1; norm_num

